---
import { partners } from "../data/partners";
---

<div class="partner-list">
  {
    partners.map((partner) => (
      <a class="partner" href={partner.url}>
        <img src={partner.logo} alt={`${partner.name} logo`} width="96" height="48" />
        <span>{partner.name}</span>
      </a>
    ))
  }
</div>

<style>
  .partner-list {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }

  .partner {
    display: flex;
    align-items: center;
    gap: 12px;
    min-height: 72px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    color: var(--text);
    padding: 14px;
  }

  img {
    width: 48px;
    height: 32px;
    object-fit: contain;
  }
</style>
