---
import { getCollection, render } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((event) => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);
const date = event.data.date.toLocaleDateString("en", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<ContentLayout title={event.data.title} description={event.data.summary} eyebrow={date}>
  {event.data.location && <p class="meta">{event.data.location}</p>}
  {event.data.image && <img src={event.data.image} alt="" />}
  <Content />
</ContentLayout>
